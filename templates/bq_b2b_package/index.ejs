    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Solution',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
        </div>
      </div>
    </div>

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
             title:'Solution',}) %>

            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Introduced standardized packages at the platform level',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Mapped packages to shopping categories',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Surfaced them on landing and browsing pages',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Enabled provider participation while maintaining flexibility',}) %>

            </div>
            <div class="spacingXSmall"></div>
          
          </div>
        </div>
      </div>
    </div>
    <div class="spacingMedium"></div>

    <div class="spacingXLarge"></div>

    <div class="spacingLarge"></div>


    <div class="spacingMedium"></div>





  </section>

  <section id="outcome" data-nav="outcome">
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
