  <section class="banner_intro">
    <div class="wrapper">
      <div class="blankHXS"></div>
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <img class="widthXXS" src="../../logos/bq.svg" alt="Logo">
            <%- include(`${templatePath}/shared/txt_banner_title`, {
            text:'Standardizing Packages to Unlock Early Funnel Discovery',}) %>
            <%- include(`${templatePath}/shared/txt_banner_description`, {
            text:'Packages drove higher conversion and AOV but were inaccessible during browsing due to provider dependency. Redesigned the system to make bundles visible earlier, enabling higher-value decisions before users commit.',}) %>
          </div>
        </div>
      </div>
    </div>
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_s`, {
            subtitle:'Context',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
            text:'BabyQuip is a two-sided marketplace with 3,000+ active providers and $20M+ annual GMV, where provider reliability and inventory quality are the primary drivers of customer trust.',}) %>
          </div>
        </div>

      </div>
      <div class="Grid Grid--gutters Grid--cols-3">
        <div class="Grid-cell">
          <div class="element">
            <h5 class="">Role: <span class="fontWeight400">Lead UX</span></h5>
          </div>
        </div>
        <div class=" Grid-cell">
          <div class="element">
            <h5 class="">Scope: <span class="fontWeight400">Marketplace package promotion</span></h5>
          </div>
        </div>
        <div class=" Grid-cell">
          <div class="element">
            <h5 class="">Stakeholders <span class="fontWeight400"><a class="textUnderline fontWeight400" href="https://www.linkedin.com/in/jemaier">Joe Maier</a>, <a class="textUnderline fontWeight400" href="https://www.linkedin.com/in/kimconnolly1">Kim Connolly</a></span></h5>
          </div>
        </div>
      </div>
      <div class="spacingXLarge"></div>

    </div>
  </section>


  <section id="problem" data-nav="problem">
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Problem',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
        </div>
      </div>
    </div>
    <div class="spacingMedium"></div>

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
            title:'Problem',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              text:'High-value bundles were only visible after selecting a provider, removing them from early browsing where most decisions happen.',}) %>

          </div>
        </div>
      </div>
    </div>
  </section>



  <section id="why_it_happens" data-nav="why_it_happens">

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Why it happens',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
        </div>
      </div>
    </div>
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
             title:'Why it happens',}) %>


            <%- include(`${templatePath}/shared/txt_description_l`, {
              text:'Because bundles were tied to individual providers, they couldn’t be displayed before a provider was selected.',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              text:'To support browsing-first shopping, bundles needed to exist independently of providers.',}) %>

          </div>
        </div>
      </div>
    </div>
    <div class="spacingMedium"></div>

    <div class="spacingMedium"></div>


    <div class="spacingMedium"></div>


  </section>

