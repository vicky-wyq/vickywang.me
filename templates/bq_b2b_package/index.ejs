             title:'Outcome',}) %>

            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Restored bundle visibility in early funnel',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Enabled bundle-based discovery',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Improved alignment with marketing goals',}) %>

            </div>
            <div class="spacingXSmall"></div>

          </div>
        </div>
