<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>BQ Provider App Sign In</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --white: #ffffff;
      --ink: #1e293b;
      --muted: #94a3b8;
      --line: #e2e8f0;
      --teal: #029db1;
      --teal-focus: #1ab9cb;
      --error: #eb568c;
      --inactive-bg: #f1f5f9;
      --inactive-line: #cbd5e1;
      --bg: #f6f7fb;
      --phone-shadow: 32px 16px 32px 6px rgba(148, 163, 184, 0.15), 8px 16px 16px 0 rgba(148, 163, 184, 0.3);
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      background: radial-gradient(circle at top, #ffffff 0%, #eef2f7 100%);
      color: var(--ink);
      font-family: Montserrat, "Avenir Next", "Segoe UI", sans-serif;
    }

    body {
      display: grid;
      place-items: center;
      padding: 24px;
    }

    .frame {
      width: 100%;
      max-width: 375px;
    }

    .phone {
      width: 100%;
      min-height: 812px;
      background: var(--white);
      border: 3px solid #111111;
      border-radius: 32px;
      box-shadow: var(--phone-shadow);
      overflow: hidden;
    }

    .screen {
      padding: 16px 32px 32px;
      min-height: 812px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .brand-wrap {
      height: 96px;
      display: flex;
      align-items: center;
      padding: 60px 0;
    }

    .brand-wrap img {
      width: 122px;
      height: 32px;
      object-fit: contain;
      object-position: left center;
      display: block;
    }

    .content {
      display: flex;
      flex-direction: column;
      gap: 32px;
      flex: 1;
    }

    .section {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .headline {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-bottom: 16px;
    }

    .headline h1,
    .headline h2 {
      margin: 0;
      font-size: 20px;
      font-weight: 600;
      line-height: 1;
      letter-spacing: 0;
    }

    .headline p {
      margin: 0;
      font-size: 14px;
      font-weight: 400;
      line-height: 1.15;
      letter-spacing: 0;
    }

    .input {
      height: 48px;
      width: 100%;
      border: 1px solid var(--muted);
      border-radius: 12px;
      background: var(--white);
      padding: 8px 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .input:focus-within {
      border-width: 2px;
      border-color: var(--teal-focus);
      padding: 7px 11px;
    }

    .input.is-error {
      border-width: 2px;
      border-color: var(--error);
      padding: 7px 11px;
    }

    .input.is-inactive {
      background: var(--inactive-bg);
      border-color: var(--inactive-line);
    }

    .input input {
      border: 0;
      outline: 0;
      width: 100%;
      height: 32px;
      font: inherit;
      font-size: 16px;
      font-weight: 600;
      color: var(--ink);
      background: transparent;
    }

    .input input::placeholder {
      color: var(--muted);
      opacity: 1;
    }

    .input.is-inactive input,
    .input.is-inactive input::placeholder,
    .input.is-inactive .input-action {
      color: var(--muted);
      background: transparent;
    }

    .input-action {
      border: 0;
      background: transparent;
      padding: 0;
      margin: 0;
      color: var(--muted);
      font: inherit;
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
    }

    .input-helper {
      display: none;
      width: 100%;
      margin-top: 4px;
      font-size: 11px;
      font-weight: 500;
      line-height: 1;
      color: var(--muted);
    }

    .input-wrap.has-error .input-helper {
      display: block;
      color: var(--error);
    }

    .input-wrap.is-inactive .input-helper {
      display: block;
      color: var(--muted);
    }

    .button-row {
      padding: 6px 0;
    }

    .button-primary,
    .button-secondary {
      width: 100%;
      height: 48px;
      border-radius: 300px;
      font: inherit;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
    }

    .button-primary {
      border: 0;
      background: var(--teal);
      color: var(--white);
    }

    .button-primary:hover,
    .button-primary:focus-visible {
      background: #17687a;
    }

    .button-secondary {
      border: 1px solid var(--teal);
      background: var(--white);
      color: var(--teal);
    }

    .button-secondary:hover,
    .button-secondary:focus-visible {
      background: #e8f8f9;
    }

    .link-button {
      display: inline-block;
      border: 0;
      background: transparent;
      padding: 0;
      margin: 0;
      color: var(--teal);
      font: inherit;
      font-size: 16px;
      font-weight: 600;
      line-height: 1;
      text-align: left;
      cursor: pointer;
    }

    .link-button:hover,
    .link-button:focus-visible {
      color: #17687a;
    }

    .divider-wrap {
      padding: 22px 0;
    }

    .divider {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
    }

    .divider-line {
      flex: 1;
      height: 1px;
      background: var(--line);
    }

    .divider span {
      padding: 0 12px;
      color: #3c475d;
      font-size: 11px;
      font-weight: 500;
      line-height: 1;
    }

    .socials {
      display: flex;
      gap: 16px;
      width: 100%;
    }

    .social-card {
      flex: 1;
      height: 64px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--white);
      display: grid;
      place-items: center;
    }

    .social-card:hover,
    .social-card:focus-visible {
      background: #f8fafc;
      border-color: #cbd5e1;
    }

    .button-primary,
    .button-secondary,
    .link-button,
    .social-card,
    .input-action {
      transition: background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease;
    }

    .button-primary:focus-visible,
    .button-secondary:focus-visible,
    .link-button:focus-visible,
    .social-card:focus-visible,
    .input-action:focus-visible {
      outline: 0;
    }

    .social-icon {
      width: 24px;
      height: 24px;
      display: block;
    }

    .sub-copy {
      max-width: 305px;
      line-height: 1.15;
    }

    @media (max-width: 420px) {
      body {
        padding: 8px;
      }
    }
  </style>
</head>
<body>
  <main class="frame">
    <section class="phone" aria-label="BQ provider sign in screen">
      <div class="screen">
        <div class="brand-wrap">
          <img src="logo.svg" alt="BabyQuip logo">
        </div>

        <div class="content">
          <div class="section">
            <div class="headline">
              <h1>Quality Provider Sign In</h1>
              <p>Manage your rentals and bookings</p>
            </div>

            <div class="input-wrap">
              <label class="input">
                <input id="email-input" type="email" placeholder="Email" aria-label="Email">
              </label>
            </div>

            <div class="input-wrap" id="password-wrap">
              <label class="input" id="password-shell">
                <input id="password-input" type="password" placeholder="Password" aria-label="Password" aria-describedby="password-helper">
                <button class="input-action" id="password-toggle" type="button">Show</button>
              </label>
              <div class="input-helper" id="password-helper">Please enter your password.</div>
            </div>

            <div class="button-row">
              <button class="button-primary" id="sign-in-button" type="button">Sign In</button>
            </div>

            <button class="link-button" type="button">Forgot password?</button>

            <div class="divider-wrap">
              <div class="divider" aria-hidden="true">
                <div class="divider-line"></div>
                <span>or</span>
                <div class="divider-line"></div>
              </div>
            </div>

            <div class="socials">
              <button class="social-card" type="button" aria-label="Continue with Facebook">
                <svg class="social-icon" viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <circle cx="12" cy="12" r="12" fill="#1877F2"></circle>
                  <path d="M13.37 20v-7.02h2.35l.35-2.74h-2.7V8.49c0-.79.22-1.33 1.36-1.33h1.46V4.71c-.25-.03-1.12-.11-2.13-.11-2.11 0-3.56 1.29-3.56 3.65v2.03H8.13v2.74h2.37V20h2.87z" fill="#fff"></path>
                </svg>
              </button>

              <button class="social-card" type="button" aria-label="Continue with Google">
                <svg class="social-icon" viewBox="0 0 24 24" role="img" aria-hidden="true">
                  <path d="M21.81 12.23c0-.72-.06-1.24-.2-1.79H12v3.38h5.64c-.11.84-.72 2.1-2.08 2.95l-.02.11 3.01 2.34.21.02c1.96-1.81 3.05-4.47 3.05-7.01z" fill="#4285F4"></path>
                  <path d="M12 22c2.76 0 5.08-.91 6.77-2.48l-3.23-2.47c-.86.6-2.02 1.02-3.54 1.02-2.7 0-4.99-1.78-5.81-4.24l-.1.01-3.13 2.43-.03.09C4.6 19.67 8.02 22 12 22z" fill="#34A853"></path>
                  <path d="M6.19 13.83A5.97 5.97 0 0 1 5.87 12c0-.63.11-1.24.3-1.83l-.01-.12-3.17-2.47-.1.05A10.03 10.03 0 0 0 2 12c0 1.61.39 3.12 1.09 4.45l3.1-2.62z" fill="#FBBC05"></path>
                  <path d="M12 5.93c1.92 0 3.21.83 3.95 1.52l2.88-2.81C17.07 3 14.76 2 12 2 8.02 2 4.6 4.33 2.89 7.63l3.28 2.54C7.01 7.71 9.3 5.93 12 5.93z" fill="#EA4335"></path>
                </svg>
              </button>
            </div>
          </div>

          <div class="section">
            <div class="headline">
              <h2>New to BabyQuip</h2>
              <p class="sub-copy">Earn Money by Renting and Delivering Baby Gear</p>
            </div>

            <div class="button-row">
              <button class="button-secondary" type="button">Become a Provider</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</body>
<script>
  (function () {
    var passwordInput = document.getElementById("password-input");
    var passwordShell = document.getElementById("password-shell");
    var passwordWrap = document.getElementById("password-wrap");
    var passwordToggle = document.getElementById("password-toggle");
    var signInButton = document.getElementById("sign-in-button");

    function setPasswordError(showError) {
      passwordShell.classList.toggle("is-error", showError);
      passwordWrap.classList.toggle("has-error", showError);
      passwordInput.setAttribute("aria-invalid", showError ? "true" : "false");
    }

    passwordToggle.addEventListener("click", function () {
      var hidden = passwordInput.type === "password";
      passwordInput.type = hidden ? "text" : "password";
      passwordToggle.textContent = hidden ? "Hide" : "Show";
    });

    passwordInput.addEventListener("input", function () {
      if (passwordInput.value.trim()) {
        setPasswordError(false);
      }
    });

    signInButton.addEventListener("click", function () {
      setPasswordError(!passwordInput.value.trim());
      if (!passwordInput.value.trim()) {
        passwordInput.focus();
      }
    });
  })();
</script>
</html>
