<!DOCTYPE html>
<html lang="en">

<!--Head-->
<%- include(`${templatePath}/shared/head`, { SEO:false, Title:`Converting High-Intent Partner Traffic Under In-App Constraints (VRBO)`,
  text:'Reducing early-stage drop-off in mobile funnels with incomplete data', pageURL:'bq_b2c_vrbo/',
  thumbnailImgURL: 'vickywang_web.png' }) %>
<!--Head-->

<body class="">


  <%- include(`${templatePath}/shared/header_back`, {
  tab1:'Problem',
  tab1_data_link:'problem', 

  tab2:'Insights',
  tab2_data_link:'insights',

  tab3:'Design',
  tab3_data_link:'design',

  tab4_display:'dispay',
  tab4:'Impact',
  tab4_data_link:'impact',
  }) %>
  <div class="wrapper">
    <div class="blankHXS"></div>
    <div class="Grid Grid--gutters Grid--full Grid--gutter">
      <div class="Grid-cell">
        <div class="element">
          <img class="widthXXS" src="../../logos/bq.svg" alt="Logo">
          <h6>Two-sided marketplace (3,000+ providers, $20M+ GMV)</h6>
          <div class="spacingMedium"></div>

          <h1 class="titleCaseStudy">Converting High-Intent Partner Traffic Under In-App Constraints (VRBO)</h1>
          <h4 class="fontWeight300">Reducing early-stage drop-off in mobile funnels with incomplete data</h4>
        </div>
      </div>
    </div>
    <div class="Grid Grid--gutters Grid--cols-3">
      <div class="Grid-cell">
        <div class="element">
          <h5 class="">Role: <span class="fontWeight400">Lead UX</span></h5>
        </div>
      </div>
      <div class=" Grid-cell">
        <div class="element">
          <h5 class="">Scope: <span class="fontWeight400">Vrbo entry, shopping, and mobile web booking flow</span></h5>
        </div>
      </div>
      <div class=" Grid-cell">
        <div class="element">
          <h5 class="">Stakeholders <span class="fontWeight400"><a class="textUnderline fontWeight400" href="https://www.linkedin.com/in/jemaier">Joe Maier</a>, <a class="textUnderline fontWeight400" href="https://www.linkedin.com/in/kimconnolly1">Kim Connolly</a></span></h5>
        </div>
      </div>
    </div>
  </div>
  <section id="problem" data-nav="problem">
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Context & Problem',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
          <div class="spacingMedium"></div>
        </div>
      </div>

      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>

            <h1 class="fontWeight400">Context</h1>

            <h4>VRBO brought high-intent, mobile-heavy traffic into BabyQuip’s embedded mobile web experience, where users entered mid-journey inside a constrained in-app browser.</h4>

            <div class="spacingMedium"></div>


            <div class="spacingMedium"></div>

            <h1 class="fontWeight400">Problem</h1>
            <h4>The experience encouraged item-first browsing even though price, availability, and fulfillment still depended on provider selection, allowing users to build carts that felt complete before a real booking could happen.
            </h4>

          </div>
          <div class="spacingMedium"></div>
        </div>
      </div>



    </div>
  </section>



  <section id="insights" data-nav="insights">

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Insights',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
          <div class="spacingMedium"></div>
        </div>
      </div>
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <h1 class="fontWeight400">Identify the issue (drop-off at top funnel)</h1>
            <div class="marginLeft">
              <h4>· Massive drop at entry → shopping</h4>
              <h4>· High completion after intent is established</h4>
              <h4>· VRBO users appeared high-intent, but less tolerant of early friction</h4>
              <div class="spacingXSmall"></div>
            </div>
          </div>
        </div>
        <div class="Grid-cell">
          <div class="element">
            <h4><span class="fontWeight400">GA4 funnel comparison: </span> VRBO vs non-VRBO traffic across mobile and web (Last 90 days)</h4>
            <img class="modal-target card2026" src="ga4.png" alt="">
          </div>
        </div>
        <div class="Grid-cell">
          <div class="element">
            <h4>Testing exposed the issue quickly, GA4 confirmed top-funnel drop-off, and session recordings provided supporting evidence of hesitation at entry.</h4>
          </div>
        </div>
        <div class="Grid-cell">
          <div class="element">

            <h4>The problem is not checkout.</h4>
            <h4>The problem is <span class="fontWeight400">failure to transition users from browsing → commitment.</span></h4>

          </div>
        </div>

      </div>




      <div class="spacingXLarge"></div>

      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <h1 class="fontWeight400">User experience across the funnel</h1>
            <div class="marginLeft">
              <h4>· <span class="fontWeight400">Entry:</span> unclear context and trust (“Where am I?”)</h4>
              <h4>· <span class="fontWeight400">Shopping:</span> misleading progress (“This feels like a real cart”)</h4>
              <h4>· <span class="fontWeight400">Commitment:</span> missing decision moment (“I haven’t actually chosen a provider”)</h4>
              <h4>· <span class="fontWeight400">Pre-checkout:</span> redundant flow (“Why am I doing this again?”)</h4>

              <div class="spacingXSmall"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="spacingXLarge"></div>

      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <h1 class="fontWeight400">Problem breakdown</h1>
          </div>
        </div>
      </div>
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <h3 class="fontWeight400">A. Entry confusion </h3>

            <div class="marginLeft">
              <h4>· Multiple overlays created a fragmented entry experience</h4>
              <h4>· Missing loading state made the app feel unresponsive</h4>
              <h4>· Unclear ownership between VRBO and BabyQuip reduced trust</h4>

              <div class="spacingXSmall"></div>
            </div>
            <img class="modal-target card2026" src="legacy_pre_entry.png" alt="">

          </div>
        </div>
      </div>
      <div class="spacingMedium"></div>

      <div class="Grid Grid--gutters Grid--full Grid--gutter">


        <div class="Grid-cell">
          <div class="element">
            <h3 class="fontWeight400">B. Shopping created false progress in a provider-dependent marketplace</h3>

            <div class="marginLeft">
              <h4>· Users added items before selecting a provider, even though pricing and availability depended on it</h4>
              <h4>· The cart appeared complete while a required step (provider selection) was still missing</h4>
              <h4>· Placeholder pricing and generic item details reinforced a false sense of certainty</h4>
              <h4>· The flow did not clearly transition users from browsing to provider selection</h4>

              <div class="spacingXSmall"></div>
            </div>
            <img class="modal-target card2026" src="legacy_shop_placeholder_items.png" alt="">

          </div>
        </div>
      </div>
      <div class="spacingMedium"></div>

      <div class="Grid Grid--gutters Grid--full Grid--gutter">


        <div class="Grid-cell">
          <div class="element">
            <h3 class="fontWeight400">C. Provider selection gap </h3>

            <div class="marginLeft">
              <h4>· Add-to-cart used success feedback, making an incomplete step feel like completion</h4>
              <h4>· CTA hierarchy favored continued browsing over provider selection</h4>
              <h4>· Provider selection was available but not treated as the next required step</h4>

              <div class="spacingXSmall"></div>
            </div>
            <img class="modal-target card2026" src="legacy_provider_selection.png" alt="">

          </div>
        </div>
      </div>
      <div class="spacingMedium"></div>

      <div class="Grid Grid--gutters Grid--full Grid--gutter">


        <div class="Grid-cell">
          <div class="element">
            <h3 class="fontWeight400">D. Pre-checkout chaos</h3>

            <div class="marginLeft">
              <h4>· Repeated states across order summary and add-ons created unnecessary loops</h4>
              <h4>· Competing CTAs made it unclear whether to continue or checkout</h4>
              <h4>· The flow resembled checkout before users were actually ready to complete</h4>

              <div class="spacingXSmall"></div>
            </div>
            <img class="modal-target card2026" src="legacy_precheckout.png" alt="">

          </div>
        </div>
      </div>
      <div class="spacingMedium"></div>

    </div>

    <div class="spacingMedium"></div>

  </section>

  <section id="design" data-nav="design">
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Design',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>

            <div class="Grid Grid--gutters Grid--full Grid--gutter">
              <div class="Grid-cell">
                <div class="element">
                  <h1 class="fontWeight400">Design principles</h1>
                </div>
              </div>
            </div>
            <div class="Grid Grid--gutters Grid--full Grid--gutter">
              <div class="Grid-cell">
                <div class="element">
                  <div>
                    <h4 class="fontWeight400">1. Clarify context before action</h4>
                    <h4>Users need to understand where they are, what carried over from VRBO, and what can be trusted before they act.</h4>

                    <h4 class="fontWeight400">2. Make commitment visible at the right moment</h4>
                    <h4>Shift the flow from endless exploration toward clear provider selection and checkout progression.</h4>
                    <h4 class="fontWeight400">3. Remove false progress and repeated decisions</h4>
                    <h4>Avoid screens and states that look complete before pricing, availability, or fulfillment are actually resolved.</h4>
                    <div class="spacingXSmall"></div>
                  </div>

                </div>
              </div>
            </div>
            <div class="spacingXLarge"></div>

            <div class="Grid Grid--gutters Grid--full Grid--gutter">
              <div class="Grid-cell">
                <div class="element">
                  <h1 class="fontWeight400">Solutions</h1>
                  <h4>Because pricing and availability were not final before provider selection, the redesign made uncertainty visible through lightweight disclaimers and contextual messaging, without blocking exploration.</h4>
                </div>
              </div>
            </div>
            <div class="Grid Grid--gutters Grid--full Grid--gutter">
              <div class="Grid-cell">
                <div class="element">
                  <h3 class="fontWeight400">1. <span class="fontWeight500">Entry:</span> Clarified entry context (VRBO-specific)</h3>
                  <div class="marginLeft">
                    <h4>· Reduce system interruptions at entry</h4>
                    <h4>· Clarify platform context and trust transfer from VRBO to BabyQuip</h4>
                    <h4>· Surface trip details early so users understand what they are booking against</h4>
                    <div class="spacingXSmall"></div>
                  </div>
                  <img class="modal-target card2026" src="design_pre_entry.png" alt="">
                </div>
              </div>
            </div>
            <div class="spacingMedium"></div>

            <div class="Grid Grid--gutters Grid--full Grid--gutter">
              <div class="Grid-cell">
                <div class="element">
                  <h3 class="fontWeight400">2.<span class="fontWeight500">Shopping:</span> Reduce false progress before provider selection (VRBO-specific)</h3>
                  <div class="marginLeft">
                    <h4>· De-emphasize placeholder pricing and incomplete item certainty</h4>
                    <h4>· Reframe add-to-cart as a transition, not a completion moment</h4>


                    <h4>· Guide users from browsing toward provider selection as the next required step</h4>
                    <div class="spacingXSmall"></div>
                  </div>
                  <img class="modal-target card2026" src="design_shopping.png" alt="">

                </div>
              </div>
            </div>
            <div class="spacingMedium"></div>

            <div class="Grid Grid--gutters Grid--full Grid--gutter">
              <div class="Grid-cell">
                <div class="element">
                  <h3 class="fontWeight400">3. <span class="fontWeight500">Commitment:</span> Make provider selection explicit at the right moment (cross-platform)</h3>
                  <div class="marginLeft">
                    <h4>· Make provider selection visible and necessary</h4>
                    <h4>· Reduce dead-end cart states before fulfillment is confirmed</h4>
                    <h4>· Align user actions with provider-based marketplace logic</h4>
                    <div class="spacingXSmall"></div>
                  </div>
                  <img class="modal-target card2026" src="design_select_provider.png" alt="">

                </div>
              </div>
            </div>
            <div class="spacingMedium"></div>

            <div class="Grid Grid--gutters Grid--full Grid--gutter">
              <div class="Grid-cell">
                <div class="element">
                  <h3 class="fontWeight400">4. <span class="fontWeight500">Pre-Checkout:</span> Remove redundant decision states (cross-platform)</h3>
                  <div class="marginLeft">
                    <h4>· Remove repeated decision states across cart, add-ons, and summary</h4>
                    <h4>· Make checkout the dominant action once users are ready to commit</h4>
                    <h4>· Consolidate add-ons, order summary, and checkout into one continuous path</h4>

                  </div>

                </div>
              </div>
            </div>

            <div class="Grid Grid--gutters Grid--cols-2">
              <div class="Grid-cell">
                <div class="element">
                  <h4><span class="fontWeight400">Before:</span> fragmented flow with repeated decision states before checkout</h4>
                  <img class="modal-target card2026" src="legacy_pre_checkout.png" alt="">
                </div>
              </div>
              <div class="Grid-cell">
                <div class="element">
                  <h4><span class="fontWeight400">After:</span> one continuous path from add-ons to checkout</h4>
                  <img class="modal-target card2026" src="design_pre_checkout.png" alt="">

                </div>
              </div>
            </div>
            <div class="spacingXSmall"></div>

          </div>
        </div>
      </div>
    </div>
    <div class="spacingMedium"></div>

  </section>

  <section id="impact" data-nav="impact">
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Impact',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>

          </div>
        </div>
      </div>
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <h1 class="fontWeight400">Expected outcome</h1>

            <div class="marginLeft">
              <h4>· Reduce early-stage drop-off by making provider selection more explicit and removing redundant pre-checkout loops.</h4>
              <h4>· Improve progression into provider selection</h4>
              <h4>· Higher completion rates after item selection maintain or improve</h4>
              <h4>· Established reusable pattern for partner traffic</h4>

              <div class="spacingXSmall"></div>
            </div>
          </div>
        </div>
        <div class="Grid-cell">
          <div class="element">
            <h1 class="fontWeight400">Measurement plan</h1>

            <div class="marginLeft">
              <h4>· Validate post-launch through GA4 funnel progression from entry → shopping → provider selection → checkout.</h4>

              <div class="spacingXSmall"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <h1 class="fontWeight400">Trade-offs</h1>

            <div class="marginLeft">
              <h4>· <span class="fontWeight400">Did not resolve provider-first vs gear-first tension</span> (placeholder items, availability still unknown before provider selection)</h4>
              <h4>· Still relies on placeholder item logic</h4>
              <h4>· Did not enable provider selection without items (explored but not shipped)</h4>
              <h4>· Limited by embedded webview + tracking gaps</h4>

              <div class="spacingXSmall"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <h1 class="fontWeight400">Forward-looking</h1>

            <h4 class="fontWeight400">Future direction:</h4>
            <h5>support dual-entry model
              (browse-first vs provider-first)</h5>
            <img class="modal-target card2026" src="design_dual-entry_model.png" alt="">
          </div>
        </div>
      </div>

    </div>

  </section>
  <!-- Case study ends -->
  <div class="blankHS"></div>
  <!-- Shared across the platform -->
  <%- include(`${templatePath}/shared/footer`) %>
  <%- include(`${templatePath}/shared/imgModal`) %>


