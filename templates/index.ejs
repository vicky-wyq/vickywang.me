<!DOCTYPE html>
<html lang="en">
<!--Head-->
<%- include(`${templatePath}/shared/head`, {SEO:true, Title:'UX/Product Designer | Vicky W.', 
  text:'UX designer focused on system clarity, scalable flows, and meaningful product impact—across both B2B platforms and consumer journeys.', 
  pageURL:'', thumbnailImgURL: 'vickywang.svg'
  }) %>
<!--Head-->


<body>
  <div class="top-glass"></div>
  <header class="top-nav">
    <div class="nav-pill" id="navPill">
      <span class="nav-pill-active" id="navActive"></span>
      <button class="nav-link is-active" data-link="casestudies" type="button">Case Studies</button>
      <button class="nav-link" data-link="explorations" type="button">Explorations</button>
      <button class="nav-link" data-link="contact" type="button">Contact</button>
    </div>
  </header>
  <div class="spacingXLarge"></div>

  <div class="spacingXLarge"></div>
  <div class="wrapper">
    <div class="Grid Grid--full Grid--gutter">
      <div class="Grid-cell">
        <div class="element">
          <div class="rowcard25 centerVer">
            <div class="photoWrappercard25">
              <img class="landingProfileImg" src="photo_profile_avatar.png" alt="vicky">
            </div>
            <div class="chat-bubble-wrap">
              <div class="card25Chat chat-bubble">
                <span class="typing">
                  <span class="dot"></span>
                  <span class="dot"></span>
                  <span class="dot"></span>
                </span>
                <span class="bubble-text"></span>
              </div>
            </div>
          </div>
          <div class="spacingXSmall"></div>
          <h1 class="card25LandingTitle"> Marketplace & platform UX for providers and travelers at scale
          </h1>
          <h2 class="fontWeight300">I turn complex provider operations and consumer funnels into clear systems that reduce friction and improve booking conversion.
          </h2>
          <h2 class="fontWeight300">I focus on how user behavior, system constraints, and product decisions shape real outcomes.</h2>
        </div>

      </div>
    </div>
    <div class="spacingXSmall"></div>

    <div class="Grid Grid--full Grid--gutter">
      <div class="element">
        <a href="/resume"> <button class="buttonMedium buttonFlip WhiteBg">View Resume </button></a>
      </div>
    </div>
    <div class="Grid Grid--full Grid--gutter">
      <div class="Grid-cell">
        <div class="element">
          <h3 class="fontWeight400"> My working principles</h3>
        </div>
      </div>
    </div>
    <div class="Grid Grid--gutters Grid--cols-3">
      <div class="Grid-cell">
        <h4 class="marginRight">Start from constraints and user behavior, not ideas
        </h4>
      </div>
      <div class="Grid-cell">
        <h4 class="marginRight"> Simplify systems before optimizing flows
        </h4>
      </div>
      <div class="Grid-cell marginRight">
        <h4 class="marginRight"> Measure success by reduced friction and clearer decisions, not feature count
        </h4>
      </div>

    </div>
  </div>


  <section id="casestudies" data-nav="casestudies">

    <div class="spacingLarge"></div>

    <%- include(`${templatePath}/shared/divider25`, {
      sectionName:'Case Studies',
      topSpacing:'spacingMedium',
      bottomSpacing:'spacingXLarge',
      topNbottomSpacing:''
      }) %>

  <div class="spacingLarge"></div>
    <%- include(`${templatePath}/shared/card_bq_inventory`) %>


    <div class="spacingLarge"></div>

    <%- include(`${templatePath}/shared/card_bq_vrbo`, {
      gated: true,
      modalId: 'checkoutAccessModalLanding'
    }) %>

  
    <div class="spacingLarge"></div>

    <%- include(`${templatePath}/shared/card_bq_package`, {
      gated: true,
      modalId: 'inventoryAccessModalLanding'
    }) %>


    <div class="spacingLarge"></div>

  </section>
  <%- include(`${templatePath}/shared/section_explorations`) %>



  <section id="contact" data-nav="contact">
    <div class="spacingLarge"></div>

    <%- include(`${templatePath}/shared/divider25`, {
      sectionName:'Contact',
      topSpacing:'spacingMedium',
      bottomSpacing:'spacingXLarge',
      topNbottomSpacing:''
      }) %>
    <div class="wrapper">
      <div class="Grid Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="rowcard25 centerVer">
              <div class="photoWrappercard25">
                <img class="landingProfileImg" src="photo_profile_avatar.png" alt="vicky">
              </div>
              <div class="chat-bubble-wrap">
                <div class="card25Chat chat-bubble">

                  <span class="bubble-text">Let's Connect</span>
                </div>
              </div>
            </div>
            <div class="spacingXSmall"></div>
            <h1 class=""> Working on marketplaces / platform UX? I’d love to hear what you’re building.
            </h1>
            <h4 class="fontWeight300">Collaborations, product discussions, or feedback on my work.</h4>
            <div class="spacingSmall"></div>
            <a href="mailto:vickyw.design@gmail.com" class="textUnderline">
              <h5 class="fontWeight400">Email me &#8594;</h5>
            </a>
            <a href="https://www.linkedin.com/in/vicky-wyq/" class="textUnderline">
              <h5 class="fontWeight400">Message me on LinkedIn &#8599; </h5>
            </a>


            <div class="spacingXLarge"></div>

            <a href="/resume"> <button class="buttonMedium buttonFlip WhiteBg">View Resume </button></a>



          </div>

        </div>
      </div>


    </div>
    <div class="spacingXLarge"></div>
    <div class="spacingXLarge"></div>
    <div class="spacingXLarge"></div>


  </section>

  <%- include(`${templatePath}/shared/footer`, {sectionName:'Contact'}) %>


</body>

</html>