<!DOCTYPE html>
<html lang="en">

<%- include(`${templatePath}/shared2026/head`, {
  headTitle: 'Vicky Wang — Product Designer, Marketplace UX',
  headDescription: 'I design both sides of a marketplace, so I fix the system, not just the screen. Product design work across supply and demand at BabyQuip.',
  headRobots: 'noindex, follow',
  headImage: 'https://vickywang.me/thumbnails/landing.png'
}) %>

<body>

  <%- include(`${templatePath}/shared2026/header`, {
    headerVariant: 'landing',
    headerHome: '#',
    headerAvatar: '../web_images/photo_profile_avatar.png',
    headerLinks: [
      { href: '#work', label: 'Case Studies', muted: true },
      { href: '#contact', label: 'Contact', muted: true }
    ]
  }) %>

  <%- include(`${templatePath}/shared2026/hero`) %>

  <section class="work container" id="work">
    <div class="work-header">
      <h2>Selected work</h2>
      <div class="work-meta">Product Design &middot; 2021 &ndash; 2026</div>
    </div>

    <%- include(`${templatePath}/shared2026/card_inventory`, {
      cardNumber: 1,
      cardHref: '/worklog/bq_b2b_inventory_management',
      cardGated: false
    }) %>

    <div class="case-grid">
      <%- include(`${templatePath}/shared2026/card_vrbo`, {
        cardNumber: 2,
        cardHref: '/worklog/bq_b2c_vrbo',
        cardGated: false
      }) %>
      <%- include(`${templatePath}/shared2026/card_checkout`, {
        cardNumber: 3,
        cardHref: '/worklog/bq_b2c_checkout',
        cardGated: false
      }) %>
    </div>

    <div class="case-grid">
      <%- include(`${templatePath}/shared2026/card_provider_app`, {
        cardNumber: 4,
        cardHref: '/worklog/bq_b2b_provider_app'
      }) %>
      <%- include(`${templatePath}/shared2026/card_package`, {
        cardNumber: 5,
        cardHref: '/worklog/bq_b2b_package',
        cardGated: false
      }) %>
    </div>
    <div class="case-grid">
      <%- include(`${templatePath}/shared2026/card_byp`, {
        cardNumber: 6,
        cardHref: '/worklog/byp_provider_platform'
      }) %>
    </div>
    <div class="work-end"></div>
  </section>

  <%- include(`${templatePath}/shared2026/footer`, {
    footerVariant: 'landing',
    footerResumeHref: '/worklog/resume'
  }) %>

</body>

</html>
