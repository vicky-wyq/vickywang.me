<!DOCTYPE html>
<html lang="en">

<%- include(`${templatePath}/shared2026/head`, {
  headTitle: 'Vicky Wang — Senior Product Designer | Marketplace & Platform UX',
  headDescription: 'Senior product designer specializing in marketplace and platform UX. I design consumer, B2B, and operational systems that improve supply, demand, and business outcomes.',
  headRobots: 'index, follow',
  headCanonical: 'https://vickywang.me/',
  headImage: 'https://vickywang.me/thumbnails/landing.png'
}) %>

<body>

  <%- include(`${templatePath}/shared2026/header`, {
    headerVariant: 'landing',
    headerHome: '#',
    headerAvatar: '../web_images/photo_profile_avatar.png',
    headerSticky: false,
    headerLinks: [
      { href: '#work', label: 'Selected Work', muted: true },
      { href: '#contact', label: 'Contact', muted: true }
    ]
  }) %>

  <%- include(`${templatePath}/shared2026/hero`) %>

  <section class="work container" id="work">
    <div class="work-header">
      <div class="work-title-group">
        <h2>Selected work</h2>
        <p class="work-note">Project previews shown below &middot; Full case studies available upon request</p>
      </div>
      <div class="work-meta">Product Design &middot; 2021 &ndash; 2026</div>
    </div>

    <%- include(`${templatePath}/shared2026/card_inventory`, {
      cardNumber: 1,
      cardHref: null,
      cardGated: true
    }) %>

    <div class="case-grid">
      <%- include(`${templatePath}/shared2026/card_vrbo`, {
        cardNumber: 2,
        cardHref: null,
        cardGated: true
      }) %>
      <%- include(`${templatePath}/shared2026/card_checkout`, {
        cardNumber: 3,
        cardHref: null,
        cardGated: true
      }) %>
    </div>

    <div class="case-grid">
      <%- include(`${templatePath}/shared2026/card_package`, {
        cardNumber: 4,
        cardHref: null,
        cardGated: true
      }) %>
      <%- include(`${templatePath}/shared2026/card_byp`, {
        cardNumber: 5,
        cardHref: '/byp_provider_platform'
      }) %>
    </div>
    <div class="work-end"></div>
  </section>

  <%- include(`${templatePath}/shared2026/footer`, {
    footerVariant: 'landing',
    footerResumeHref: '/resume2026'
  }) %>

  <div class="wl-case-modal" id="case-modal">
    <div class="wl-case-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="case-modal-title">
      <button type="button" class="wl-case-modal__close" aria-label="Close">&times;</button>
      <div class="wl-case-modal__header">
        <span class="wl-case-modal__icon">
          <svg width="13" height="15" viewBox="0 0 13 15" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1" y="6" width="11" height="8" rx="1.5" stroke="currentColor" stroke-width="1.4"></rect>
            <path d="M3.5 6V4.5C3.5 2.84 4.84 1.5 6.5 1.5C8.16 1.5 9.5 2.84 9.5 4.5V6" stroke="currentColor" stroke-width="1.4"></path>
            <circle cx="6.5" cy="10" r="1.2" fill="currentColor"></circle>
          </svg>
        </span>
        <div class="wl-case-modal__label-group">
          <span class="wl-case-modal__eyebrow">PRIVATE CASE STUDY</span>
          <span class="wl-case-modal__case-label" data-modal-case-label></span>
        </div>
      </div>
      <div class="wl-case-modal__body">
        <h3 class="wl-case-modal__title" id="case-modal-title">Full case study available <em>privately</em></h3>
        <p class="wl-case-modal__text">This project includes internal product details and is not publicly accessible. I&rsquo;m happy to share the complete case study with hiring teams.</p>
        <div class="wl-case-modal__actions">
          <a href="mailto:vickyw.design@gmail.com" class="wl-case-modal__btn wl-case-modal__btn--accent" data-modal-email>Email me for access &rarr;</a>
          <a href="/resume2026" class="wl-case-modal__btn wl-case-modal__btn--outline">View resume <span aria-hidden="true">↗</span><span class="sr-only">, opens resume page</span></a>
        </div>
        <div class="wl-case-modal__email-copy" aria-live="polite">
          <span data-modal-copy-email>vickyw.design@gmail.com</span>
          <button type="button" class="wl-case-modal__copy-btn" data-modal-copy-btn aria-label="Copy email address">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
              <rect x="5" y="5" width="8" height="8" rx="1.3" stroke="currentColor" stroke-width="1.4"></rect>
              <path d="M3 10.5H2.8C2.36 10.5 2 10.14 2 9.7V2.8C2 2.36 2.36 2 2.8 2H9.7C10.14 2 10.5 2.36 10.5 2.8V3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></path>
            </svg>
          </button>
        </div>
        <div class="wl-case-modal__note">
          <span class="wl-case-modal__dot"></span>
          <span>Usually replies within 24 hours</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var modal = document.getElementById('case-modal');
      var labelEl = modal.querySelector('[data-modal-case-label]');
      var emailLink = modal.querySelector('[data-modal-email]');
      var copyEmailEl = modal.querySelector('[data-modal-copy-email]');
      var copyBtn = modal.querySelector('[data-modal-copy-btn]');
      var closeBtn = modal.querySelector('.wl-case-modal__close');
      var triggers = document.querySelectorAll('[data-modal-trigger]');
      var lastFocused = null;
      var copyResetTimer = null;

      function openModal(trigger) {
        var num = trigger.getAttribute('data-case-num') || '';
        var title = trigger.getAttribute('data-case-title') || '';
        labelEl.textContent = (num ? num + ' · ' : '') + title;
        emailLink.href = 'mailto:vickyw.design@gmail.com?subject=' + encodeURIComponent('Case study access request — ' + title);
        lastFocused = document.activeElement;
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        closeBtn.focus();
      }

      function closeModal() {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
        if (lastFocused) lastFocused.focus();
      }

      function copyText(text) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          return navigator.clipboard.writeText(text);
        }

        var textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.setAttribute('readonly', '');
        textArea.style.position = 'fixed';
        textArea.style.opacity = '0';
        document.body.appendChild(textArea);
        textArea.select();

        try {
          document.execCommand('copy');
          return Promise.resolve();
        } catch (error) {
          return Promise.reject(error);
        } finally {
          document.body.removeChild(textArea);
        }
      }

      copyBtn.addEventListener('click', function() {
        var email = copyEmailEl.textContent.trim();
        copyText(email).then(function() {
          copyBtn.setAttribute('aria-label', 'Email copied');
          copyBtn.classList.add('is-copied');
          window.clearTimeout(copyResetTimer);
          copyResetTimer = window.setTimeout(function() {
            copyBtn.setAttribute('aria-label', 'Copy email address');
            copyBtn.classList.remove('is-copied');
          }, 1400);
        });
      });

      triggers.forEach(function(trigger) {
        trigger.addEventListener('click', function(e) {
          e.preventDefault();
          openModal(trigger);
        });
      });

      modal.addEventListener('click', function(e) {
        if (e.target === modal) closeModal();
      });

      closeBtn.addEventListener('click', closeModal);

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
      });
    })();
  </script>

</body>

</html>
