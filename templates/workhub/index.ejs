<!DOCTYPE html>
<html lang="en">
<!--Head-->
<%- include(`${templatePath}/shared/head`, {SEO:false, Title:'Product Designer | Vicky W.', 
  description:'UX designer focused on system clarity, scalable flows, and meaningful product impact—across both B2B platforms and consumer journeys.', 
  pageURL:'card25', thumbnailImgURL: 'vickywang.svg'
  }) %>
<!--Head-->

<body>
  <div class="top-glass"></div>
  <header class="top-nav">
    <div class="nav-pill" id="navPill">
      <span class="nav-pill-active" id="navActive"></span>
      <button class="nav-link is-active" data-link="casestudies" type="button">Case Studies</button>
      <button class="nav-link" data-link="explorations" type="button">Explorations</button>
      <button class="nav-link" data-link="contact" type="button">Contact</button>
    </div>
  </header>
  <div class="spacingXLarge"></div>

  <div class="spacingXLarge"></div>
  <div class="wrapper">
    <div class="Grid Grid--full Grid--gutter">
      <div class="Grid-cell">
        <div class="element">
          <div class="rowcard25 centerVer">
            <div class="photoWrappercard25">
              <img class="landingProfileImg" src="photo_profile_avatar.png" alt="vicky">
            </div>
            <div class="chat-bubble-wrap">
              <div class="card25Chat chat-bubble">
                <span class="typing">
                  <span class="dot"></span>
                  <span class="dot"></span>
                  <span class="dot"></span>
                </span>
                <span class="bubble-text"></span>
              </div>
            </div>
          </div>
          <div class="spacingXSmall"></div>
          <h1 class="card25LandingTitle"> Marketplace & platform UX for providers and travelers
          </h1>
          <h3 class="fontWeight300">I design scalable provider tools and high-traffic consumer flows for marketplaces, reducing operational friction and increasing booking conversion.
          </h3>
        </div>

      </div>
    </div>
    <div class="Grid Grid--full Grid--gutter">
      <div class="element">
        <a href="/resume2025"> <button class="buttonMedium buttonFlip WhiteBg">View Resume </button></a>
      </div>
    </div>
    <div class="Grid Grid--full Grid--gutter">
      <div class="Grid-cell">
        <div class="element">
          <h3 class="fontWeight400"> My working principles</h3>
        </div>
      </div>
    </div>
    <div class="Grid Grid--gutters Grid--cols-3">
      <div class="Grid-cell">
        <h4 class="marginRight">Start from constraints, not ideas
        </h4>
      </div>
      <div class="Grid-cell">
        <h4 class="marginRight"> Collapse systems before polishing flows
        </h4>
      </div>
      <div class="Grid-cell marginRight">
        <h4 class="marginRight"> Measure success by reduced friction, not feature count
        </h4>
      </div>

    </div>
  </div>


  <section id="casestudies" data-nav="casestudies">

    <div class="spacingLarge"></div>

    <%- include(`${templatePath}/shared/divider25`, {
      sectionName:'Case Studies',
      topSpacing:'spacingMedium',
      bottomSpacing:'spacingXLarge',
      topNbottomSpacing:''
      }) %>


    <div class="wrapper">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Consumer Facing • Q1 2026 </p>
          <h2 class="fontWeight400">Improving Checkout Conversion by Reducing Early-Stage Friction
          </h2>

          <h4 class="fontWeight400">
            Improving cart-to-checkout transition and early-stage completion, especially on mobile.

          </h4>
          <h4 class="">
            Users dropped off before and at the start of checkout, limiting revenue from high-intent traffic.
            Redesigned the transition to checkout and simplified early-stage interactions to improve commitment and completion.
          </h4>

          <div class="card__cta">
            <h4>↓ Drop-off before checkout, ↑ completion rate, ↓ early drop-off</h4>
            <div class="spacingSmall"></div>

            <a href="/bq_b2c_checkout">
              <button class="buttonMedium buttonPrimary">View Case Study</button>
            </a>
          </div>
          <div class="spacingXSmall displayMobile"></div>
        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/projectImages/cover_bqCheckout.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>
    <div class="spacingLarge"></div>


    <div class="wrapper">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Consumer Facing • Q1 2026 </p>
          <h2 class="fontWeight400">Converting High-Intent Partner Traffic Under In-App Constraints (VRBO)</h2>

          <h4 class="fontWeight400">Reducing early-stage drop-off in mobile funnels with incomplete data
          </h4>
          <h4 class="">Partner-driven users dropped off early due to lack of context and trust. Redesigned the entry and decision flow to help more high-intent users progress into and through the funnel without increasing acquisition.
          </h4>

          <div class="card__cta">

            <h4>↓ Drop-off, ↑ checkout progression</h4>
            <div class="spacingSmall"></div>

            <a href="/bq_b2c_vrbo">
              <button class="buttonMedium buttonPrimary">View Case Study</button>
            </a>
          </div>
          <div class="spacingXSmall displayMobile"></div>
        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/projectImages/cover_bqVrbo.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>
    <div class="spacingLarge"></div>

    <div class="spacingLarge"></div>
    <div class="wrapper">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Business Facing Partner Portal • Q3 2025</p>
          <h2 class="fontWeight400">Unlocking Supply Growth by Simplifying Inventory Management</h2>
          <h4 class="">Redesigned inventory management to reduce operational overhead for high-volume providers, enabling more frequent updates and unlocking underutilized supply.</h4>
          <div class="card__cta">
            <h4>↓ interaction cost · 3× faster edits for high-volume providers</h4>
            <div class="spacingSmall"></div>

            <a href="/bq_b2b_inventory_management">
              <button class="buttonMedium buttonPrimary">View Case Study</button>
            </a>
          </div>
          <div class="spacingXSmall displayMobile"></div>
        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/projectImages/cover_bq_inventory_management.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>

    <div class="spacingLarge"></div>

    <div class="wrapper">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Business-Facing • Q3 2025</p>
          <h2 class="fontWeight400">Restoring Bundle Discovery in a Browsing-First Marketplace</h2>
          <h4>Packages were hidden during early browsing, limiting conversion and order value. Introduced standardized packages to surface bundles earlier and support higher-value decisions.</h4>


          <div class="card__cta">
            <h4>↑ bundle visibility · ↑ early-stage engagement · ↑ conversion potential</h4>
            <div class="spacingSmall"></div>

            <a href="/bq_b2b_package">
              <button class="buttonMedium buttonPrimary">View Case Study</button>
            </a>
          </div>
          <div class="spacingXSmall displayMobile"></div>





        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/projectImages/cover_bq_package.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>

    <div class="spacingLarge"></div>



  </section>


  <section id="explorations" data-nav="explorations">
    <div class="spacingLarge"></div>

    <%- include(`${templatePath}/shared/divider25`, {
      sectionName:'Explorations',
      topSpacing:'spacingMedium',
      bottomSpacing:'spacingXLarge',
      topNbottomSpacing:''
      }) %>
    <div class="wrapper">
      <div class="Grid Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">


            <h2 class="fontWeight400">Design System &amp; Implementation Thinking</h2>

            <h5 class="card25CardDescription">A personal design system built and iterated since 2020 to test layout scalability, accessibility, and design–code parity across real production surfaces.</h5>
          </div>
        </div>
      </div>

      <div class="Grid Grid--full Grid--gutter">
        <div class="Grid-cell u-textCenter">
          <div class="element">
            <div class="paddingL borderRadiusL gradient_background1">
              <div class="element bgTransWhite paddingL borderRadiusM">

                <h1 class="specialDS ">VICKYWANG.ME</h1>

              </div>
            </div>
          </div>
        </div>
      </div>


      <div class="Grid Grid--full Grid--gutter">
        <div class="Grid-cell u-textCenter">
          <div class="element">
            <a href="/design_system/"> <button class="buttonMedium buttonFlip">View Design System</button>
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <section id="contact" data-nav="contact">
    <div class="spacingLarge"></div>

    <%- include(`${templatePath}/shared/divider25`, {
      sectionName:'Contact',
            topSpacing:'spacingMedium',
      bottomSpacing:'spacingXLarge',
      topNbottomSpacing:''
      }) %>
    <div class="wrapper">
      <div class="Grid Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="rowcard25 centerVer">
              <div class="photoWrappercard25">
                <img class="landingProfileImg" src="photo_profile_avatar.png" alt="vicky">
              </div>
              <div class="chat-bubble-wrap">
                <div class="card25Chat chat-bubble">

                  <span class="bubble-text">Let's Connect</span>
                </div>
              </div>
            </div>
            <div class="spacingXSmall"></div>
            <h1 class=""> Working on marketplaces / platform UX? I’d love to hear what you’re building.
            </h1>
            <h4 class="fontWeight300">Collaborations, product discussions, or feedback on my work.</h4>
            <div class="spacingSmall"></div>
            <a href="mailto:vickyw.design@gmail.com" class="textUnderline">
              <h5 class="fontWeight400">Email me &#8594;</h5>
            </a>
            <a href="https://www.linkedin.com/in/vicky-wyq/" class="textUnderline">
              <h5 class="fontWeight400">Message me on LinkedIn &#8599; </h5>
            </a>


            <div class="spacingXLarge"></div>

            <a href="/resume2025"> <button class="buttonMedium buttonFlip WhiteBg">View Resume </button></a>



          </div>

        </div>
      </div>


    </div>
    <div class="spacingXLarge"></div>
    <div class="spacingXLarge"></div>
    <div class="spacingXLarge"></div>


  </section>

  <%- include(`${templatePath}/shared/footer`, {sectionName:'Contact'}) %>


</body>

</html>