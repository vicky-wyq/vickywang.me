<!DOCTYPE html>
<html lang="en">
<!--Head-->
<%- include(`${templatePath}/shared/head`, {SEO:false, Title:'Product Designer | Vicky W.', 
  text:'UX designer focused on system clarity, scalable flows, and meaningful product impact—across both B2B platforms and consumer journeys.', 
  pageURL:'workhub', thumbnailImgURL: 'vickywang.svg'
  }) %>
<!--Head-->

<body>
  <div class="top-glass"></div>
  <header class="top-nav">
    <div class="nav-pill" id="navPill">
      <span class="nav-pill-active" id="navActive"></span>
      <button class="nav-link is-active" data-link="casestudies" type="button">Case Studies</button>
      <button class="nav-link" data-link="explorations" type="button">Explorations</button>
      <button class="nav-link" data-link="contact" type="button">Contact</button>
    </div>
  </header>
  <div class="spacingXLarge"></div>

  <div class="spacingXLarge"></div>
  <div class="wrapper">
    <div class="Grid Grid--full Grid--gutter">
      <div class="Grid-cell">
        <div class="element">
          <div class="rowcard25 centerVer">
            <div class="photoWrappercard25">
              <img class="landingProfileImg" src="photo_profile_avatar.png" alt="vicky">
            </div>
            <div class="chat-bubble-wrap">
              <div class="card25Chat chat-bubble">
                <span class="typing">
                  <span class="dot"></span>
                  <span class="dot"></span>
                  <span class="dot"></span>
                </span>
                <span class="bubble-text"></span>
              </div>
            </div>
          </div>
          <div class="spacingXSmall"></div>
          <h1 class="card25LandingTitle"> Marketplace & platform UX for providers and travelers at scale
          </h1>
          <h2 class="fontWeight300">I turn complex provider operations and consumer funnels into clear systems that reduce friction and improve booking conversion.
          </h2>
          <h2 class="fontWeight300">I focus on how user behavior, system constraints, and product decisions shape real outcomes.</h2>
        </div>

      </div>
    </div>
              <div class="spacingXSmall"></div>

    <div class="Grid Grid--full Grid--gutter">
      <div class="element">
        <a href="/resume"> <button class="buttonMedium buttonFlip WhiteBg">View Resume </button></a>
      </div>
    </div>
    <div class="Grid Grid--full Grid--gutter">
      <div class="Grid-cell">
        <div class="element">
          <h3 class="fontWeight400"> My working principles</h3>
        </div>
      </div>
    </div>
    <div class="Grid Grid--gutters Grid--cols-3">
      <div class="Grid-cell">
        <h4 class="marginRight">Start from constraints and user behavior, not ideas
        </h4>
      </div>
      <div class="Grid-cell">
        <h4 class="marginRight"> Simplify systems before optimizing flows
        </h4>
      </div>
      <div class="Grid-cell marginRight">
        <h4 class="marginRight"> Measure success by reduced friction and clearer decisions, not feature count
        </h4>
      </div>

    </div>
  </div>


  <section id="casestudies" data-nav="casestudies">

    <div class="spacingLarge"></div>

    <%- include(`${templatePath}/shared/divider25`, {
      sectionName:'Case Studies',
      topSpacing:'spacingMedium',
      bottomSpacing:'spacingXLarge',
      topNbottomSpacing:''
      }) %>


    <div class="wrapper">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Consumer Facing • Q2 2026 </p>
          <h2 class="fontWeight400">Improving Checkout Conversion by Reducing Early-Stage Friction
          </h2>

          <h4 class="fontWeight400">
            Improving cart-to-checkout transition and early-stage completion, especially on mobile.

          </h4>
          <h4 class="">
            Users dropped off before and at the start of checkout, limiting revenue from high-intent traffic.
            Redesigned the transition to checkout and simplified early-stage interactions to improve commitment and completion.
          </h4>

          <div class="card__cta">
            <h4>↓ Drop-off before checkout, ↑ completion rate, ↓ early drop-off</h4>
            <div class="spacingSmall"></div>

            <a href="/bq_b2c_checkout">
              <button class="buttonMedium buttonPrimary">View Case Study</button>
            </a>
          </div>
          <div class="spacingXSmall displayMobile"></div>
        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/project_images/cover_bqCheckout.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>
    <div class="spacingLarge"></div>


    <div class="wrapper">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Consumer Facing • Q2 2026 </p>
          <h2 class="fontWeight400">Converting High-Intent Partner Traffic Under In-App Constraints (VRBO)</h2>

          <h4 class="fontWeight400">Reducing early-stage drop-off in mobile funnels with incomplete data
          </h4>
          <h4 class="">High-intent partner traffic dropped off early as the experience suggested progress without real commitment (e.g., unconfirmed pricing and placeholder items). Redesigned entry and decision flow to align user actions with marketplace logic.
          </h4>

          <div class="card__cta">

            <h4>↓ Drop-off, ↑ checkout progression</h4>
            <div class="spacingSmall"></div>

            <a href="/bq_b2c_vrbo">
              <button class="buttonMedium buttonPrimary">View Case Study</button>
            </a>
          </div>
          <div class="spacingXSmall displayMobile"></div>
        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/project_images/cover_bqVrbo.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>
    <div class="spacingLarge"></div>

    <div class="spacingLarge"></div>
    <div class="wrapper">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Business Facing Partner Portal • Q3 2025</p>
          <h2 class="fontWeight400">Unlocking Supply Growth Through Streamlined Inventory Management</h2>
          <h4 class="">Simplified fragmented inventory workflows into a unified management system, enabling faster updates and unlocking underutilized supply.</h4>
          <div class="card__cta">
            <h4>↓ interaction cost · 3× faster edits for high-volume providers</h4>
            <div class="spacingSmall"></div>

            <a href="/bq_b2b_inventory_management">
              <button class="buttonMedium buttonPrimary">View Case Study</button>
            </a>
          </div>
          <div class="spacingXSmall displayMobile"></div>
        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/project_images/cover_bq_inventory_management.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>

    <div class="spacingLarge"></div>

    <div class="wrapper">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Business-Facing • Q3 2025</p>
          <h2 class="fontWeight400">Integrating Bundles into Early-Stage Discovery</h2>
          <h4>Shifted packages from post-selection upsells to a primary entry point through item-level mapping</h4>


          <div class="card__cta">
            <h4>↑ bundle visibility · ↑ early-stage engagement · ↑ conversion potential</h4>
            <div class="spacingSmall"></div>

            <a href="/bq_b2b_package">
              <button class="buttonMedium buttonPrimary">View Case Study</button>
            </a>
          </div>
          <div class="spacingXSmall displayMobile"></div>





        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/project_images/cover_bq_package.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>

    <div class="spacingLarge"></div>



