  tab2_data_link:'insight',

  tab3:'Strategy',
  tab3_data_link:'strategy',

  tab4_display:'displayTab',
  tab4:'Solution',
  tab4_data_link:'solution',
  }) %>
  <section>
    <div class="wrapper">
      <div class="blankHXS"></div>
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
