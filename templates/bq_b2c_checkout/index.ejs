      <div class="accItem">
        <div class="Grid Grid--gutters Grid--cols-2 Grid--top accTrigger">
          <div class="Grid-cell">
            <div class="element">
              <h4 class="fontWeight400">Mobile checkout has ~2x higher drop-off than desktop</h4>
              <h6>Mobile web users are significantly less likely to complete checkout compared to desktop users, with nearly 2x higher drop-off at the checkout entry step.</h6>
            </div>
          </div>
          <div class="align-right">
            <div class="element">
              <div class="accIcon iconAccTrigger"></div>
            </div>
          </div>
        </div>
        <div class="accContent" style="">
          <div class="Grid Grid--gutters Grid--full Grid--gutter">
            <div class="Grid-cell">
              <div class="element">
                <h6>Funnel:</h6>
                <h6><span class="fontWeight400"> Web: </span>~84% completion from begin_checkout → purchase </h6>
                <h6><span class="fontWeight400"> Mobile web:</span> ~46% completion </h6>
              </div>
            </div>
            <div class="spacingSmall"></div>

          </div>

        </div>

      </div>

