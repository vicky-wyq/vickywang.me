      <div class="Grid Grid--gutters Grid--cols-2">
        <div class="Grid-cell">
          <div class="element">

            <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Option 1 — Add a separate discovery surface',}) %>
                <img class="modal-target card2026" src="wireframe_opt1.png" alt="Option 1 — Add a separate discovery surface">

            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Improves category visibility',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Requires providers to leave the core inventory workflow',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Adds another place to check, making adoption unlikely during routine updates',}) %>

            </div>

 

          </div>
        </div>

        <div class="Grid-cell">
          <div class="element">


            <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Option 2 — Integrate discovery into inventory management',}) %>
                            <img class="modal-target card2026" src="wireframe_opt2.png" alt="Option 2 — Integrate discovery into inventory management">

            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Reduces interaction cost by keeping discovery inside the editing flow',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Surfaces listed and unlisted gear while providers are already managing inventory',}) %>

              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Scales with inventory growth without adding another navigation layer',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'',}) %>
            </div>

   
          </div>

        </div>
      </div>


      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'A separate discovery surface would add visibility but not reduce effort. Embedding discovery into the existing workflow made exposure part of routine inventory management.',}) %>
            <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Decision:',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'Chose Option 2 after internal reviews and QP validation because it addressed discovery and interaction cost through the same workflow.',}) %>
          </div>
        </div>
      </div>
    </div>


    </div>

