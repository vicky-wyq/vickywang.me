                  <td class="fontWeight400">Top 10%</td>
                  <td>559</td>
                  <td>46.3%</td>
                  <td>High-volume QPs with the most complete listings</td>
                </tr>
                <tr>
                  <td class="fontWeight400">Next 20%</td>
                  <td>1,117</td>
                  <td>31.7%</td>
                  <td>Mid-tier QPs with moderate listing depth</td>
                </tr>
                <tr>
                  <td class="fontWeight400">Remaining 70%</td>
                  <td>3,913</td>
                  <td>21.9%</td>
                  <td>Smaller catalogs or lower platform engagement</td>
                </tr>
              </tbody>
            </table>

            <div class="spacingSmall"></div>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· The top 10% of QPs contributed 46.3% of total supply, making their workflow the highest-leverage problem to solve',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Inventory updates competed with delivery, cleaning, and customer coordination, reducing update frequency',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Unlisted and underused gear stayed hidden in separate flows, increasing CS support and onboarding friction',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                text:'· Adding another tab would improve exposure but also add another navigation step',}) %>

            <div class="spacingSmall"></div>


            <h2 class="fontWeight100">As inventory scales, navigation-heavy workflows make management inefficient, especially for the providers driving most marketplace supply.</h2>




