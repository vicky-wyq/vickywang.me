<!DOCTYPE html>
<html lang="en">

<!--Head-->
<%- include(`${templatePath}/shared/head`, { SEO:false, Title:`Scaling Inventory Management for Growth
`,
  description:'Enhancing the Consumer Booking Experience', pageURL:'bq_b2b_inventory_management/',
  thumbnailImgURL: 'vickywang_web.png' }) %>
<!--Head-->

<body class="">
  <%- include(`${templatePath}/shared/header_back`, {
  tab1:'Constraint',
  tab1_data_link:'constraint',

  tab2:'Reframe',
  tab2_data_link:'reframe',

  tab3:'Intervention',
  tab3_data_link:'intervention',

  tab4_display:'dispay',
  tab4:'Impact',
  tab4_data_link:'impact',
  }) %>
  <section class="banner_intro">
    <div class="wrapper">
      <div class="blankHXS"></div>
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <img class="widthXXS" src="../../logos/bq.svg" alt="Logo">
            <%- include(`${templatePath}/shared/txt_banner_title`, {
            bannerTitle:'Eliminating Navigation Bottlenecks in Inventory Management',}) %>
            <%- include(`${templatePath}/shared/txt_banner_subtitle`, {
            bannerSubtitle:'Redesigned inventory management to eliminate navigation as a bottleneck, enabling high-volume providers to efficiently manage and scale marketplace supply.',}) %>
          </div>
        </div>
      </div>
    </div>
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_s`, {
            subtitle:'Context',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
            descriptionL:'BabyQuip is a two-sided marketplace with 3,000+ active providers and $20M+ annual GMV, where provider reliability and inventory quality are the primary drivers of customer trust.',}) %>
          </div>
        </div>

      </div>
      <div class="Grid Grid--gutters Grid--cols-3">
        <div class="Grid-cell">
          <div class="element">
            <h5 class="">Role: <span class="fontWeight400">Lead UX</span></h5>
          </div>
        </div>
        <div class=" Grid-cell">
          <div class="element">
            <h5 class="">Scope: <span class="fontWeight400">Gear listing &amp; storefront control</span></h5>
          </div>
        </div>
        <div class=" Grid-cell">
          <div class="element">
            <h5 class="">Stakeholders <span class="fontWeight400"><a class="textUnderline fontWeight400" href="https://www.linkedin.com/in/jemaier">Joe Maier</a>, <a class="textUnderline fontWeight400" href="https://www.linkedin.com/in/kimconnolly1">Kim Connolly</a></span></h5>
          </div>
        </div>
      </div>
      <div class="spacingXLarge"></div>

    </div>
  </section>


  <section id="constraint" data-nav="constraint">
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Constraint',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
        </div>
      </div>
    </div>
    <div class="spacingMedium"></div>

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
            title:'Constraint',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'Inventory management did not scale with supply growth.',}) %>
            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'· Editing required 4–5 clicks with frequent context switching',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'· Inventory split across multiple views with no single overview',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'· Filters disappeared during navigation, forcing re-orientation',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'· 45% of categories remained undiscovered or unused',}) %>
            </div>
            <h4>As inventory increased, <span class="fontWeight400"> the cost to manage it increased faster than the inventory itself</span> reducing update frequency and leaving supply underutilized.</h4>
          </div>
        </div>
      </div>
    </div>
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Legacy Flow:',}) %>
          <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'Fragmented, navigation-driven updates that reset context',}) %>
          <img class="modal-target card2025" src="flow_im_before.png" alt="Legacy Flow">

        </div>

      </div>
    </div>


  </section>



  <section id="reframe" data-nav="reframe">

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Reframe',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
        </div>
      </div>
    </div>
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
             title:'Task',}) %>


            <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'Initially asked to improve category discoverability by adding a new tab.',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'This assumed a visibility problem.',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'Analysis showed the real constraint was interaction cost, not lack of entry points.',}) %>

          </div>
        </div>
      </div>
    </div>
    <div class="spacingMedium"></div>

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
             title:'Findings',}) %>
            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· High-volume QPs (top 10%) contributed 46.3% of total supply but faced the highest management burden',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Managing inventory competed with operational work (delivery, cleaning), so updates were infrequent',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· New or unlisted gear remained hidden, requiring CS support and increasing onboarding friction',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Additional navigation (e.g., new tabs) would increase complexity without improving usage',}) %>
            </div>
            <div class="spacingSmall"></div>

            <table>
              <thead>
                <tr>
                  <th class="fontWeight400">% of QPs</th>
                  <th class="fontWeight400"># of QPs</th>
                  <th class="fontWeight400">% of Supply Index</th>
                  <th class="fontWeight400">What It Means</th>
                </tr>
              </thead>
              <tbody>
                <tr class="colorBgYellowVW300">
                  <td class="fontWeight400">Top 10%</td>
                  <td>559</td>
                  <td>46.3%</td>
                  <td>High-volume QPs managing the most complete listings</td>
                </tr>
                <tr>
                  <td class="fontWeight400">Next 20%</td>
                  <td>1,117</td>
                  <td>31.7%</td>
                  <td>Mid-tier QPs, active but less comprehensive</td>
                </tr>
                <tr>
                  <td class="fontWeight400">Remaining 70%</td>
                  <td>3,913</td>
                  <td>21.9%</td>
                  <td>Smaller catalogs or lower platform engagement</td>
                </tr>
              </tbody>
            </table>

            <div class="spacingSmall"></div>


            <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Conclusion:',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'As inventory scales, navigation-heavy workflows make management inefficient, especially for the providers who drive most of the marketplace supply.',}) %>
          </div>
        </div>
      </div>
    </div>
    <div class="spacingMedium"></div>

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
             title:'Approach',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'Evaluated two directions:',}) %>

            <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Option 1 - Add discovery tab',}) %>
            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Improves visibility of categories',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Maintains fragmented workflows',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Adds another navigation layer',}) %>
            </div>
            <div class="wrapper">
              <div class="Grid Grid--gutters Grid--full Grid--gutter">
                <div class="Grid-cell">
                  <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Wireframe:',}) %>
                  <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'Unlisted Gear for Discoverbility',}) %>
                  <img class="modal-target card2025" src="wireframe_opt1.png" alt="Legacy Flow">

                </div>

              </div>
            </div>
            <div class="spacingXSmall"></div>

            <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Option 2 - Integrate discovery into management (recommended)',}) %>
            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Reduces interaction cost',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Enables editing and discovery in the same workflow',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Scales with increasing inventory',}) %>
            </div>

            <div class="spacingXSmall"></div>
            <div class="wrapper">
              <div class="Grid Grid--gutters Grid--full Grid--gutter">
                <div class="Grid-cell">
                  <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Wireframe:',}) %>
                  <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'Single tab that easy to discover during gear editing',}) %>
                  <img class="modal-target card2025" src="wireframe_opt2.png" alt="Legacy Flow">

                </div>

              </div>
            </div>
            <%- include(`${templatePath}/shared/txt_title_s`, {
                title:'Decision:',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'Chose Option 2 after internal reviews and QP validation, as it addressed both efficiency and discoverability at the system level.',}) %>
          </div>
        </div>
      </div>
    </div>

    <div class="spacingMedium"></div>


  </section>

  <section id="intervention" data-nav="intervention">



    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Intervention',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
        </div>
      </div>
    </div>

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
             title:'Intervention',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'Reduced inventory management to a single, continuous interaction loop.',}) %>
            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Unified all inventory into one surface (replaced multi-screen navigation)',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Enabled inline editing to eliminate context switching',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Persisted filters to maintain orientation during scanning',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Surfaced listed and unlisted gear in the same workflow',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Added "View Shop" to connect provider actions with customer-facing output',}) %>
            </div>
            <div class="spacingXSmall"></div>
            <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'This shifted the system from navigation-driven UI to a data-driven control surface.',}) %>
          </div>
        </div>
      </div>
    </div>
    <div class="spacingMedium"></div>
    <div class="wrapper">

      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'From fragmented navigation → to continuous inline management',}) %>
          </div>
        </div>
      </div>
      <div class="Grid Grid--gutters Grid--cols-2">
        <div class="Grid-cell">
          <img class="modal-target card2025" src="flow_im_before.png" alt="">
          <h4><span class="fontWeight400">Before:</span> Fragmented, navigation-driven updates that reset context</h4>

        </div>
        <div class="Grid-cell">
          <div class="element">
            <img class="modal-target card2025" src="flow_im_after.png" alt="">
            <h4><span class="fontWeight400">After:</span> Unified inventory with persistent filters and inline actions</h4>

          </div>
        </div>
      </div>
    </div>
    <div class="spacingXLarge"></div>

    <div class="wrapper">
      <div class="TBcarousel Grid--center Grid Grid--gutters Grid--full u-textCenter" aria-label="TBcarousel" tabindex="0" id="TBcarousel1">
        <div class="TBslides">
          <div class="TBslidesItem slide-1" id="slide-1" aria-label="slide 1 of 4" tabindex="0">
            <div class="crop_mockup">
              <img src="after_one_unified_view.gif" alt="1 unified view">
            </div>
          </div>
          <div class="TBslidesItem slide-2" id="slide-2" aria-label="slide 2 of 4" tabindex="0">
            <div class="crop_mockup">
              <img src="after_persistent_filters.gif" alt="Persistent filters">
            </div>
          </div>
          <div class="TBslidesItem slide-3" id="slide-3" aria-label="slide 3 of 4" tabindex="0">
            <div class="crop_mockup">
              <img src="after_inline_editing.gif" alt="Inline editing">
            </div>
          </div>
        </div>
        <div class="blankHXXS"></div>

        <div class="TBcarouselNav Grid-cell flipBtn">
          <a class="TBsliderNav" aria-label="Go to slide 1" tabindex="0">
            <div>1 unified view</div>
          </a>
          <a class="TBsliderNav active" aria-label="Go to slide 2" tabindex="0">
            <div>Persistent filters</div>
          </a>
          <a class="TBsliderNav" aria-label="Go to slide 3" tabindex="0">
            <div>Inline editing</div>
          </a>
        </div>
        <div class="blankHXXS"></div>
      </div>
    </div>
    <div class="spacingMedium"></div>





  </section>

  <section id="impact" data-nav="impact">
    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <div class="blankHXXS"></div>
            <%- include(`${templatePath}/shared/divider25`, {
            sectionName:'Impact',
            topSpacing:'spacingMedium',
            bottomSpacing:'spacingXLarge',
            topNbottomSpacing:''
            }) %>
          </div>
        </div>
      </div>
    </div>

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
             title:'Impact',}) %>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'By removing navigation as the primary constraint:',}) %>
            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· 3x faster edits for high-volume providers',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Increased activation of previously unused categories and inventory',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Reduced CS and QA overhead caused by fragmented workflows',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Improved inventory freshness and completeness',}) %>
            </div>
            <div class="spacingXSmall"></div>
            <%- include(`${templatePath}/shared/txt_description_l`, {
              descriptionL:'Established a scalable foundation for expanding categories and supply (e.g., GoQuip and future marketplace growth).',}) %>
          </div>
        </div>
      </div>
    </div>

    <div class="wrapper">
      <div class="Grid Grid--gutters Grid--full Grid--gutter">
        <div class="Grid-cell">
          <div class="element">
            <%- include(`${templatePath}/shared/txt_title_l`, {
             title:'System Outcome',}) %>
            <div class="marginLeft">
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Reduced interaction cost per item to increase update frequency',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Increased inventory visibility to improve supply utilization',}) %>
              <%- include(`${templatePath}/shared/txt_description_l`, {
                descriptionL:'· Enabled supply growth without proportional operational overhead',}) %>
            </div>
          </div>
        </div>
      </div>
    </div>


  </section>
  <!-- Case study ends -->
  <div class="blankHS"></div>
  <!-- Shared across the platform -->
  <%- include(`${templatePath}/shared/footer`) %>
  <%- include(`${templatePath}/shared/imgModal`) %>


