      <div class="Grid Grid--gutters Grid--cols-3">
        <div class="Grid-cell">
          <div class="element">
            <h5 class="fontWeight500 grey750">Role:</h5>
            <h5>Lead UX for provider inventory management redesign</h5>
          </div>
        </div>
        <div class="Grid-cell">
          <div class="element">
            <h5 class="fontWeight500 grey750">Scope:</h5>

            <h5>Provider-facing B2B workflow redesign · inventory operations · category expansion</h5>
          </div>
        </div>
        <div class="Grid-cell">
          <div class="element">
            <h5 class="fontWeight500 grey750">Stakeholders:</h5>

            <h5>VP Product Design, CTO, engineering, QA, providers (QPs)</h5>
          </div>
        </div>
      </div>

      <div class="spacingXLarge"></div>

