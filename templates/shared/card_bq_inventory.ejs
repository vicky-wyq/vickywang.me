<% if (typeof gated === 'undefined') {
  gated = false;
} %>
<% if (typeof ctaButton === 'undefined') {
  ctaButton = 'buttonPrimary';
} %>
<% if (typeof modalId === 'undefined') {
  modalId = 'inventoryAccessModal';
} %>

<div class="wrapper">
  <div class="card">
    <div class="card__left">
      <p class="card25CardMeta">Business Facing Partner Portal • Q3 2025</p>
      <h2 class="fontWeight400">Reducing Operational Friction to Unlock Marketplace Supply</h2>
      <h4 class="">Redesigned fragmented provider inventory workflows into a unified operational surface, embedding discovery directly into inventory management and reducing maintenance overhead for high-volume providers.</h4>
      <div class="card__cta">
        <h4>↓ operational friction · ↑ faster inventory management at scale</h4>
        <div class="spacingSmall"></div>

        <% if (gated) { %>
        <%- include(`${templatePath}/shared/modal_email_for_access`, {
                ctaButton,
                modalId
              }) %>
        <% } else { %>
        <a href="/bq_b2b_inventory_management">
          <button class="buttonMedium <%= ctaButton %>">View Case Study</button>
        </a>
        <% } %>
      </div>
      <div class="spacingXSmall displayMobile"></div>
    </div>

    <div class="card__right">
      <div class="card25-media">
        <img src="/project_images/cover_bq_inventory_management.png" alt="project image" class="card25-media-img">
      </div>
    </div>
  </div>
</div>