<% if (typeof gated === 'undefined') {
  gated = false;
} %>
<% if (typeof ctaButton === 'undefined') {
  ctaButton = 'buttonPrimary';
} %>
<% if (typeof modalId === 'undefined') {
  modalId = 'checkoutAccessModal';
} %>

<div class="wrapper">
  <div class="card">
    <div class="card__left">
      <p class="card25CardMeta">Consumer Facing • Q2 2026 </p>
      <h2 class="fontWeight400">Reducing Checkout Friction After Renters Are Ready to Book

      </h2>

      <h4 class="">
        Checkout is the commitment phase. The redesign protected that moment by resolving identity earlier, keeping order-critical tasks in checkout, and moving nonessential prompts after purchase. </h4>


      <div class="card__cta">
        <h4>↓ late-stage blockers · ↓ account errors · ↑ checkout focus</h4>
        <div class="spacingSmall"></div>

        <% if (gated) { %>
        <%- include(`${templatePath}/shared/modal_email_for_access`, {
                ctaButton,
                modalId
              }) %>
        <% } else { %>
        <a href="/bq_b2c_checkout">
          <button class="buttonMedium <%= ctaButton %>">View Case Study</button>
        </a>
        <% } %>
      </div>
      <div class="spacingXSmall displayMobile"></div>
    </div>

    <div class="card__right">
      <div class="card25-media">
        <img src="/project_images/cover_bq_checkout.png" alt="project image" class="card25-media-img">
      </div>
    </div>
  </div>
</div>