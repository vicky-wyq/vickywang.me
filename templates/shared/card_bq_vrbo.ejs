
<% if (typeof gated === 'undefined') {
  gated = false;
} %>
<% if (typeof ctaButton === 'undefined') {
  ctaButton = 'buttonPrimary';
} %>
<% if (typeof modalId === 'undefined') {
  modalId = 'vrboAccessModal';
} %>

    <div class="wrapper colorBgWhite">
      <div class="card">
        <div class="card__left">
          <p class="card25CardMeta">Consumer Facing • Q2 2026 </p>
          <h2 class="fontWeight400">Converting VRBO Partner Traffic into Rental Intent</h2>

          <h5>Reduced early mobile drop-off by aligning partner entry, pricing clarity, and shopping flow with marketplace constraints.</h5>

          <div class="card__cta">

            <h5>Lower early-stage drop-off · Better-aligned partner entry</h5>
            <div class="spacingSmall"></div>

            <% if (gated) { %>
              <%- include(`${templatePath}/shared/modal_email_for_access`, {
                ctaButton,
                modalId
              }) %>
            <% } else { %>
              <a href="/bq_b2c_vrbo">
                <button class="buttonMedium <%= ctaButton %>">View Case Study</button>
              </a>
            <% } %>
          </div>
          <div class="spacingXSmall displayMobile"></div>
        </div>

        <div class="card__right">
          <div class="card25-media">
            <img src="/project_images/cover_bq_b2c_vrbo.png" alt="project image" class="card25-media-img">
          </div>
        </div>
      </div>
    </div>
